{
  "manifest_version": 3,
  "name": "Brain Shadow — Grok",
  "version": "1.0",
  "description": "Extract Grok AI conversations and sync to Brain Shadow.",
  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "scripting",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "https://grok.com/*",
    "https://x.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://grok.com/*", "https://x.com/i/grok*"],
      "js": ["fetch.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
