NODE_ENV=production

# Railway provides PORT automatically. Keep this unset in Railway unless you need it locally.
# PORT=8000

# Use Railway MongoDB's connection string, or your MongoDB Atlas URI.
# The backend also accepts Railway's MONGO_URL or a standard DATABASE_URL.
MONGODB_URI=mongodb://user:password@host:port/brain-shadow?authSource=admin

# Comma-separated frontend origins allowed by CORS.
FRONTEND_URL=https://your-frontend-service.up.railway.app

AI_PROVIDER=groq
# Two separate Groq keys, one per workload, so each gets its own
# 14,400 req/day quota instead of sharing one. Both fall back to
# GROQ_API_KEY (single-key) if their specific var isn't set.
GROQ_API_KEY_SUMMARY=your-groq-api-key-for-enrichment
GROQ_API_KEY_CHAT=your-groq-api-key-for-search-chat
# GROQ_API_KEY=your-groq-api-key
CEREBRAS_API_KEY=your-cerebras-api-key
BACKEND_API_KEY=change-this-secret
LOG_LEVEL=info

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
JWT_SECRET=generate-a-long-random-secret
