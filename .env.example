# Combined-deployment (Dockerfile / Railway single service):
# NEXT_PUBLIC_API_URL and BACKEND_URL are set inside the Dockerfile itself
# (relative "/backend" and internal "http://localhost:8000" respectively) —
# you don't need to set them here for that setup.
#
# Only running the frontend as its own separate service? Uncomment and point
# these at the backend's public URL instead:
# NEXT_PUBLIC_API_URL=https://your-backend-service.up.railway.app
# BACKEND_URL=https://your-backend-service.up.railway.app

# Public Google OAuth client ID — required at BUILD time (Next.js inlines
# NEXT_PUBLIC_* vars into the client bundle). Set this as a Railway Variable
# so it's available during the Docker build, not just at runtime.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
